# Copy to .env and fill in actual values. Do NOT commit .env.
# All vars must be set at build time (CRA bakes them into the bundle).

# Public-facing URL of this frontend (used for share links, etc.)
REACT_APP_URL=https://app.example.com

# Backend REST APIs
REACT_APP_API_URL=https://api.example.com
REACT_APP_BACKEND_URL_BASE=https://api.example.com
REACT_APP_BACKEND_WEBFLUX_URL_BASE=https://reactive.example.com
REACT_APP_BACKEND_NUMBER=1
REACT_APP_BACKEND_PORTS=7070

# Rust WebSocket server (real-time dashboard updates).
# MUST be wss:// in production (browser blocks ws:// from HTTPS pages).
REACT_APP_WS_URL_BASE=wss://ws.example.com

# Object storage (Backblaze B2 / S3)
REACT_APP_BUCKET_URL=https://s3.example.com/
REACT_APP_IMAGE_URL_START=your-bucket-name

# Stripe — pk_test_... in dev, pk_live_... in prod
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME

# Sentry (leave empty to disable). DSN is public-safe.
REACT_APP_SENTRY_DSN=
REACT_APP_SENTRY_ENV=production
REACT_APP_SENTRY_RELEASE=
