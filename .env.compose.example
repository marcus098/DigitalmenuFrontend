# Copy to .env (same directory as docker-compose.yml) and fill in real values.
# Compose reads this file automatically when running `docker compose up`.
# NEVER commit the resulting .env.

# --- URLs (use https/wss in production) ---
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8085
WEBFLUX_URL=http://localhost:8081
WS_URL=ws://localhost:8083

# --- Database ---
POSTGRES_DB=digitalmenu
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# --- Object storage (Backblaze B2) ---
BUCKET_URL=https://s3.us-west-001.backblazeb2.com/
BUCKET_NAME=your-bucket-name
BUCKET_S3_ENDPOINT=https://s3.us-west-001.backblazeb2.com
BUCKET_S3_REGION=us-west-001
BUCKET_S3_ACCESSKEY=REPLACE_ME
BUCKET_S3_SECRETKEY=REPLACE_ME

# --- Stripe ---
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# --- WS auth (when Rust WS service is wired up) ---
JWT_SECRET=REPLACE_WITH_RANDOM_256_BIT_HEX
